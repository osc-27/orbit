# ── Orbit environment ────────────────────────────────────────────────────────
# Copy to .env.local for development. All optional in the mock preview build.

# Signs the OppFi handoff prefill token. MUST be set to a strong secret in prod.
ORBIT_HANDOFF_SECRET=

# OppFi decisioning API — when both are set, the oppfi adapter uses the live
# client instead of mock data (see src/lib/oppfi/client.ts).
ORBIT_OPPFI_API_URL=
ORBIT_OPPFI_API_KEY=

# Destination for the OppLoans application handoff (defaults to opploans.com).
ORBIT_OPPLOANS_APPLY_URL=

# Engine by MoneyLion (network adapter) — for the future live rate-table client.
ORBIT_ENGINE_API_URL=
ORBIT_ENGINE_API_KEY=
